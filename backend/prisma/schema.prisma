// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String?   @db.VarChar(255)
  email         String    @unique @db.VarChar(255)
  emailVerified DateTime?
  image         String?   @db.Text
  accounts      Account[]
  sessions      Session[]
  ratings       Rating[]
  achievements  UserAchievement[]
}

model Account {
  id                 Int     @id @default(autoincrement())
  userId             Int
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Achievement {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String
  icon        String?  // Name of lucide icon or image asset
  points      Int      @default(0)
  users       UserAchievement[]
}

model UserAchievement {
  id            Int      @id @default(autoincrement())
  userId        Int
  achievementId Int
  status        String   @default("APPROVED") // APPROVED, PENDING, REJECTED
  earnedAt      DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

model Rating {
  id Int @id @default(autoincrement())
  libraryName String @db.VarChar(255)
  rating Int // 0 to 100
  goodForGroups Boolean
  isLoud Boolean
  floor String @db.VarChar(255)
  latitude      Float?
  longitude     Float?
  createdAt DateTime @default(now())
  libraryId      Int?
  library        Library? @relation(fields: [libraryId], references: [id])
  user      User?  @relation(fields: [userId], references: [id])  // optional relation
  userId    Int?   // nullable foreign key
  @@index([libraryName, createdAt, libraryId]) //This index makes the 'where' clause instant for 'library'
}

model Library {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  googleUrl       String   @db.Text
  
  address        String?  @db.VarChar(255)
  imageSrc       String?  @db.Text
  studySpaceUrl  String?  @db.Text
  services       String?  @db.Text
  hasStudySpace  Boolean  @default(false)
  
  currentBusyness Int      @default(0)
  isOpen          Boolean  @default(false)
  lastUpdated     DateTime @default(now())

  weeklySchedule  Json? 
  ratings         Rating[]
  logs            TrafficLog[]
}

model TrafficLog {
  id          Int      @id @default(autoincrement())
  libraryId   Int
  library     Library  @relation(fields: [libraryId], references: [id])
  busyness    Int
  createdAt   DateTime @default(now())

  @@index([libraryId, createdAt])
}
