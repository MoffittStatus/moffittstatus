// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique @db.VarChar(255)
  name     String?   @db.VarChar(255)
  ratings  Rating[]
  bookings Booking[]
  bookingRequests UserBookingRequest[]
}

model Rating {
  id Int @id @default(autoincrement())
  libraryName String @db.VarChar(255)
  rating Int // 0 to 100
  goodForGroups Boolean
  isLoud Boolean
  floor String @db.VarChar(255)
  latitude      Float?
  longitude     Float?
  createdAt DateTime @default(now())
  libraryId      Int?
  library        Library? @relation(fields: [libraryId], references: [id])
  user      User?  @relation(fields: [userId], references: [id])  // optional relation
  userId    Int?   // nullable foreign key
  @@index([libraryName, createdAt, libraryId]) //This index makes the 'where' clause instant for 'library'
}

model Library {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  googleUrl       String   @db.Text

  address        String?  @db.VarChar(255)
  imageSrc       String?  @db.Text
  studySpaceUrl  String?  @db.Text
  services       String?  @db.Text
  hasStudySpace  Boolean  @default(false)

  currentBusyness Int      @default(0)
  isOpen          Boolean  @default(false)
  lastUpdated     DateTime @default(now())

  weeklySchedule  Json?
  ratings         Rating[]
  logs            TrafficLog[]
  bookings        Booking[]
  bookingRequests UserBookingRequest[]
}

enum BookingRequestStatus {
  RECEIVED
  COMPLETED
  FAILED
  ABANDONED
}

enum BookingLocationType {
  LIBRARY
  CAMPUS_SPACE
  OTHER
}

model UserBookingRequest {
  id               Int                  @id @default(autoincrement())

  // User intent
  requestedStart   DateTime
  requestedEnd     DateTime

  // Location context
  locationType     BookingLocationType  @default(LIBRARY)
  locationName     String?              @db.VarChar(255)  // e.g. Main Stacks, Soda, Cory
  locationCode     String?              @db.VarChar(100)  // optional short code used by upstream systems

  // LibCal context (optional; may be absent for non-LibCal sources)
  libcalLibraryId  String?              @db.VarChar(50)   // lid (legacy naming kept for compatibility)
  libcalRoomId     String?              @db.VarChar(50)   // eid
  slotChecksum     String?              @db.VarChar(255)

  // Request lifecycle
  status           BookingRequestStatus @default(RECEIVED)

  // Relations
  userId           Int?
  user             User?                @relation(fields: [userId], references: [id])

  libraryId        Int?
  library          Library?             @relation(fields: [libraryId], references: [id])

  bookingId        Int?                 @unique
  booking          Booking?             @relation(fields: [bookingId], references: [id])

  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([userId, createdAt])
  @@index([libraryId, createdAt])
  @@index([status, createdAt])
  @@index([locationType, locationName, requestedStart])
  @@index([libcalLibraryId, requestedStart, requestedEnd])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

model Booking {
  id              Int           @id @default(autoincrement())

  // LibCal identifiers
  roomId          String        @db.VarChar(50)   // LibCal eid
  groupId         String        @db.VarChar(50)   // LibCal gid
  libcalLibraryId String        @db.VarChar(50)   // LibCal lid (≠ our DB id)
  tempBookingId   String?       @db.VarChar(100)  // returned by LibCal on temp booking
  checksum        String?       @db.VarChar(255)  // LibCal slot checksum
  redirectUrl     String?       @db.Text          // final booking URL sent to user

  // Time
  startTime       DateTime
  endTime         DateTime
  duration        Int           // minutes

  // Status (library-side view)
  status          BookingStatus @default(PENDING)

  // User — nullable placeholder until login is implemented
  userId          Int?
  user            User?         @relation(fields: [userId], references: [id])

  // Library FK
  libraryId       Int?
  library         Library?      @relation(fields: [libraryId], references: [id])

  bookingRequest  UserBookingRequest?

  createdAt       DateTime      @default(now())

  @@index([libraryId, startTime])
  @@index([status])
  @@index([roomId, startTime])
}

model TrafficLog {
  id          Int      @id @default(autoincrement())
  libraryId   Int
  library     Library  @relation(fields: [libraryId], references: [id])
  busyness    Int
  createdAt   DateTime @default(now())

  @@index([libraryId, createdAt])
}
